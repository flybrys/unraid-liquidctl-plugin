/* Fan curve cards */
.curve-card { background: var(--s1); border: 1px solid var(--border); border-radius: 10px; padding: 18px 20px; }
.curve-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.curve-title { font-size: 12px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }
