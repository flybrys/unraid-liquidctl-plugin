}
.gauge-unit {
  font-family: var(--font-mono);
  font-size: 14px; color: var(--muted); margin-left: 3px;
}
.gauge-sub {
  font-size: 12px; color: var(--muted); margin-top: 6px;
  font-family: var(--font-mono);
}
.gauge-bar-wrap {
  margin-top: 10px; height: 3px; background: var(--s3); border-radius: 2px; overflow: hidden;
}
.gauge-bar {
  height: 100%; border-radius: 2px;
  background: var(--col, var(--accent));
  transition: width .6s ease;
}

/* ---- Charts row ---- */
.charts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
@media (max-width: 900px) { .charts-grid { grid-template-columns: 1fr; } }

.chart-card { background: var(--s1); border: 1px solid var(--border); border-radius: 10px; padding: 18px 20px; }
.chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
.chart-title { font-size: 12px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }
.chart-legend { display: flex; gap: 14px; }
