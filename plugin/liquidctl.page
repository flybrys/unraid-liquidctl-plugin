<script>
/* ----
   cerebro-aio dashboard JS
   ---- */

const CSRF = "<?=$var['csrf_token'] ?? ''?>";
const API = '/plugins/liquidctl/api.php' + (CSRF ? ('?csrf_token=' + encodeURIComponent(CSRF)) : '');

// ---- Chart.js setup ----
Chart.defaults.color = '#454d62';
Chart.defaults.borderColor = 'rgba(35,38,48,.5)';
Chart.defaults.font.family = "'Share Tech Mono', monospace";
Chart.defaults.font.size = 11;

const chartOpts = (yLabel, min, max) => ({
  responsive: true, maintainAspectRatio: false, animation: false,
  interaction: { mode: 'index', intersect: false },
  plugins: { legend: { display: false }, tooltip: { displayColors: true } },
  scales: {
    x: { ticks: { maxTicksLimit: 6, maxRotation: 0 }, grid: { color: 'rgba(35,38,48,.5)' } },
    y: {
      min, suggestedMax: max,
      ticks: { maxTicksLimit: 5 },
      grid: { color: 'rgba(35,38,48,.5)' },
      title: { display: true, text: yLabel }
    }
  }
});

const mkDataset = (label, color, data=[]) => ({
  label, data, borderColor: color, backgroundColor: color + '18',
  borderWidth: 1.5, pointRadius: 0, tension: 0.3, fill: true
});

const tempChart = new Chart(
  document.getElementById('tempChart').getContext('2d'),
  { type: 'line', data: { labels: [], datasets: [mkDataset('Temp degC', '#ff7043')] }, options: chartOpts('degC', 20, 60) }
);

const speedChart = new Chart(
  document.getElementById('speedChart').getContext('2d'),
  {
    type: 'line',
    data: { labels: [], datasets: [
      mkDataset('Fan 1', '#40c4ff'),
      mkDataset('Fan 2', '#80d8ff'),
      mkDataset('Pump',  '#b388ff'),
    ]},
    options: chartOpts('RPM', 0, 3000)
  }
);

function updateCharts(history) {
  const N = 150; // last 5 min @ 2s
  const slice = history.slice(-N);
  const labels = slice.map(p => {
    const d = new Date(p.ts);
    return `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}:${String(d.getSeconds()).padStart(2,'0')}`;
  });

  tempChart.data.labels                  = labels;
  tempChart.data.datasets[0].data        = slice.map(p => p.liquid_temp ?? null);
  tempChart.update('none');

  speedChart.data.labels                 = labels;
  speedChart.data.datasets[0].data       = slice.map(p => p.fan1_speed ?? null);
  speedChart.data.datasets[1].data       = slice.map(p => p.fan2_speed ?? null);
  speedChart.data.datasets[2].data       = slice.map(p => p.pump_speed ?? null);
  speedChart.update('none');
}

// ---- Gauge updates ----
function tempColor(t) {
  if (t < 35) return 'var(--ok)';
  if (t < 45) return 'var(--warn)';
  return 'var(--hot)';
}
function tempLabel(t) {
  if (t < 35) return 'Cool';
  if (t < 45) return 'Warm';
  return 'HOT';
}

function updateGauges(s) {
  const t = s.liquid_temp ?? null;

  if (t !== null) {
    window.currentLiquidTemp = t;
    // Re-render curve editors so the temp indicator updates
    if (window.editors) {
      if (editors[1]) editors[1].render();
      if (editors[2]) editors[2].render();
    }
    document.getElementById('gTemp').textContent   = t.toFixed(1);
    document.getElementById('gTempState').textContent = tempLabel(t);
    document.getElementById('gTempBar').style.cssText =
      `width:${Math.min(100, (t-20)/40*100).toFixed(1)}%; background:${tempColor(t)}`;
    document.getElementById('gTemp').style.color = tempColor(t);
  }

  const f1 = s.fan1_speed ?? null, f1d = s.fan1_duty ?? null;
  const f2 = s.fan2_speed ?? null, f2d = s.fan2_duty ?? null;
  const pp = s.pump_speed ?? null, ppd = s.pump_duty ?? null;

  if (f1 !== null) {
    document.getElementById('gFan1').textContent     = f1.toLocaleString();
    document.getElementById('gFan1Duty').textContent = `Duty ${f1d}%`;
    document.getElementById('gFan1Bar').style.width  = `${f1d}%`;
  }
  if (f2 !== null) {
    document.getElementById('gFan2').textContent     = f2.toLocaleString();
    document.getElementById('gFan2Duty').textContent = `Duty ${f2d}%`;
    document.getElementById('gFan2Bar').style.width  = `${f2d}%`;
  }
  if (pp !== null) {
    document.getElementById('gPump').textContent     = pp.toLocaleString();
    document.getElementById('gPumpDuty').textContent = `Duty ${ppd}%`;
    document.getElementById('gPumpBar').style.width  = `${ppd}%`;
    const rpmEl  = document.getElementById('pumpRpmLarge');
    const dutyEl = document.getElementById('pumpDutyDisplay');
    if (rpmEl)  rpmEl.innerHTML  = `${pp.toLocaleString()}<span style='font-size:12px;color:var(--muted)'> rpm</span>`;
    if (dutyEl) dutyEl.innerHTML = `${ppd}<span style='font-size:12px;color:var(--muted)'> %</span>`;
  }
}

// ---- Settings state ----
let currentSettings = null;

function highlightPumpMode(mode) {
  document.querySelectorAll('.pump-btn').forEach(b =>
    b.classList.toggle('active', b.dataset.mode === mode)
  );
}

async function setPumpMode(mode) {
  if (!currentSettings) return;
  currentSettings.pump_mode = mode;
  highlightPumpMode(mode);
  await saveSettings(currentSettings);
}

// ---- Curve editor class ----
class CurveEditor {
  constructor(canvasId, curve, onChange) {
    this.canvas = document.getElementById(canvasId);
    this.ctx    = this.canvas.getContext('2d');
    this.curve  = curve.map(p => [...p]);  // deep copy
    this.onChange   = onChange;
    this.deleteMode = false;
    this.dragging   = null;
    this.tMin = 20; this.tMax = 60;
    this.dMin = 0;  this.dMax = 100;
    this.pad  = { top: 24, right: 20, bottom: 38, left: 46 };

    this.canvas.addEventListener('mousedown',  e => this._md(e));
    this.canvas.addEventListener('mousemove',  e => this._mm(e));
    this.canvas.addEventListener('mouseup',    () => { this.dragging = null; });
    this.canvas.addEventListener('mouseleave', () => { this.dragging = null; });
    this.canvas.addEventListener('click',      e => this._click(e));
    // Touch support
    this.canvas.addEventListener('touchstart', e => { e.preventDefault(); this._md(e.touches[0]); }, {passive:false});
    this.canvas.addEventListener('touchmove',  e => { e.preventDefault(); this._mm(e.touches[0]); }, {passive:false});
    this.canvas.addEventListener('touchend',   () => { this.dragging = null; });

    this.render();
  }

  _mp(e) {
    const r = this.canvas.getBoundingClientRect();
    const scaleX = this.canvas.width  / r.width;
    const scaleY = this.canvas.height / r.height;
    return { x: (e.clientX - r.left) * scaleX, y: (e.clientY - r.top) * scaleY };
  }

  _tc(temp, duty) {
    const {top,right,bottom,left} = this.pad;
    const w = this.canvas.width  - left - right;
    const h = this.canvas.height - top  - bottom;
    return {
      x: left + (temp - this.tMin) / (this.tMax - this.tMin) * w,
      y: top  + (1    - (duty - this.dMin) / (this.dMax - this.dMin)) * h,
    };
  }

  _fc(x, y) {
    const {top,right,bottom,left} = this.pad;
    const w = this.canvas.width  - left - right;
    const h = this.canvas.height - top  - bottom;
    return {
      temp: this.tMin + (x - left) / w * (this.tMax - this.tMin),
      duty: this.dMin + (1 - (y - top) / h) * (this.dMax - this.dMin),
    };
  }

  _hit(x, y) {
    const R = 12;
    for (let i = 0; i < this.curve.length; i++) {
      const {x:cx, y:cy} = this._tc(this.curve[i][0], this.curve[i][1]);
      if (Math.hypot(x-cx, y-cy) < R) return this.curve[i];
    }
    return null;
  }

  _md(e) {
    const {x,y} = this._mp(e);
    const hit = this._hit(x, y);
    if (hit && !this.deleteMode) this.dragging = hit;
  }

  _mm(e) {
    if (!this.dragging) return;
    const {x,y} = this._mp(e);
    const {temp,duty} = this._fc(x, y);
    this.dragging[0] = Math.max(this.tMin, Math.min(this.tMax, Math.round(temp)));
    this.dragging[1] = Math.max(0,         Math.min(100,       Math.round(duty)));
    this.curve.sort((a,b) => a[0]-b[0]);
    this.render();
    this.onChange(this.curve);
  }

  _click(e) {
    const {x,y} = this._mp(e);
    const hit = this._hit(x, y);
    if (this.deleteMode) {
      if (hit && this.curve.length > 2) {
        this.curve.splice(this.curve.indexOf(hit), 1);
        this.render();
        this.onChange(this.curve);
      }
      return;
    }
    if (!hit) {
      const {temp,duty} = this._fc(x, y);
      const t = Math.max(this.tMin, Math.min(this.tMax, Math.round(temp)));
      const d = Math.max(0,         Math.min(100,       Math.round(duty)));
      this.curve.push([t, d]);
      this.curve.sort((a,b) => a[0]-b[0]);
      this.render();
      this.onChange(this.curve);
    }
  }

  setCurve(curve) {
    this.curve = curve.map(p => [...p]);
    this.render();
  }

  render() {
    const ctx = this.ctx;
    const W = this.canvas.width, H = this.canvas.height;
    const {top:pt, right:pr, bottom:pb, left:pl} = this.pad;
    const aW = W - pl - pr, aH = H - pt - pb;

    ctx.clearRect(0, 0, W, H);

    // Background
    const bg = ctx.createLinearGradient(0, 0, 0, H);
    bg.addColorStop(0, '#0d0f15');
    bg.addColorStop(1, '#08090d');
    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, W, H);

    // Subtle grid
    ctx.strokeStyle = '#1a1c26';
    ctx.lineWidth = 1;
    for (let t = this.tMin; t <= this.tMax; t += 5) {
      const {x} = this._tc(t, 0);
      ctx.beginPath(); ctx.moveTo(x, pt); ctx.lineTo(x, H-pb); ctx.stroke();
    }
    for (let d = 0; d <= 100; d += 25) {
      const {y} = this._tc(this.tMin, d);
      ctx.beginPath(); ctx.moveTo(pl, y); ctx.lineTo(W-pr, y); ctx.stroke();
    }

    // Axis labels
    ctx.fillStyle = '#3a4254';
    ctx.font = `10px 'Share Tech Mono', monospace`;
    for (let t = 20; t <= 60; t += 10) {
      const {x} = this._tc(t, 0);
      ctx.textAlign = 'center';
      ctx.fillText(t+'deg', x, H-pb+14);
    }
    for (let d = 0; d <= 100; d += 25) {
      const {y} = this._tc(this.tMin, d);
      ctx.textAlign = 'right';
      ctx.fillText(d+'%', pl-6, y+4);
    }

    // Axis titles
    ctx.fillStyle = '#3a4254';
    ctx.font = `10px 'Rajdhani', sans-serif`;
    ctx.textAlign = 'center';
    ctx.fillText('Temperature (degC)', pl + aW/2, H-1);
    ctx.save();
    ctx.translate(9, pt + aH/2);
    ctx.rotate(-Math.PI/2);
    ctx.fillText('Duty %', 0, 0);
    ctx.restore();

    if (this.curve.length === 0) return;

    const sorted = [...this.curve].sort((a,b) => a[0]-b[0]);

    // Filled area
    ctx.beginPath();
    const {x:x0, y:_} = this._tc(sorted[0][0], 0);
    ctx.moveTo(Math.max(pl, x0), H-pb);
    sorted.forEach(([t,d]) => { const p = this._tc(t,d); ctx.lineTo(p.x, p.y); });
    const {x:xL} = this._tc(sorted[sorted.length-1][0], 0);
    ctx.lineTo(Math.min(W-pr, xL), H-pb);
    ctx.closePath();
    ctx.fillStyle = 'rgba(0,200,224,.06)';
    ctx.fill();

    // Curve line (extend to edges)
    ctx.beginPath();
    ctx.moveTo(pl, this._tc(this.tMin, sorted[0][1]).y);
    sorted.forEach(([t,d]) => { const p = this._tc(t,d); ctx.lineTo(p.x, p.y); });
    ctx.lineTo(W-pr, this._tc(this.tMax, sorted[sorted.length-1][1]).y);
    ctx.strokeStyle = '#00c8e0';
    ctx.lineWidth = 1.5;
    ctx.shadowColor = '#00c8e044';
    ctx.shadowBlur = 6;
    ctx.stroke();
    ctx.shadowBlur = 0;

    // Current temperature indicator (vertical line at current liquid temp)
    if (typeof window.currentLiquidTemp === 'number') {
      const t = window.currentLiquidTemp;
      if (t >= this.tMin && t <= this.tMax) {
        const {x: tx} = this._tc(t, 0);
        // Vertical line
        ctx.save();
        ctx.strokeStyle = '#ff7043';
        ctx.lineWidth = 1;
        ctx.setLineDash([3, 3]);
        ctx.beginPath();
        ctx.moveTo(tx, pt);
        ctx.lineTo(tx, H - pb);
        ctx.stroke();
        ctx.setLineDash([]);

        // Find the duty at this temperature from the curve
        const sortedC = [...this.curve].sort((a,b) => a[0]-b[0]);
        const targetDuty = (() => {
          if (t <= sortedC[0][0]) return sortedC[0][1];
          if (t >= sortedC[sortedC.length-1][0]) return sortedC[sortedC.length-1][1];
          for (let i = 0; i < sortedC.length - 1; i++) {
            const [t0, d0] = sortedC[i], [t1, d1] = sortedC[i+1];
            if (t0 <= t && t <= t1) {
              return d0 + (d1 - d0) * (t - t0) / (t1 - t0);
            }
          }
          return sortedC[sortedC.length-1][1];
        })();

        // Highlight dot at intersection
        const {x: ix, y: iy} = this._tc(t, targetDuty);
        ctx.beginPath();
        ctx.arc(ix, iy, 4, 0, Math.PI*2);
        ctx.fillStyle = '#ff7043';
        ctx.fill();
        ctx.strokeStyle = '#fff';
        ctx.lineWidth = 1;
        ctx.stroke();

        // Label
        const labelTxt = `${t.toFixed(1)}deg -> ${Math.round(targetDuty)}%`;
        ctx.font = `9px 'Share Tech Mono', monospace`;
        const tw = ctx.measureText(labelTxt).width;
        const lblX = Math.min(Math.max(tx, pl + tw/2 + 4), W - pr - tw/2 - 4);
        const lblY = pt + 12;
        ctx.fillStyle = 'rgba(255,112,67,.95)';
        ctx.fillRect(lblX - tw/2 - 3, lblY - 9, tw + 6, 12);
        ctx.fillStyle = '#08090d';
        ctx.textAlign = 'center';
        ctx.fillText(labelTxt, lblX, lblY);
        ctx.restore();
      }
    }

    // Drag points
    this.curve.forEach(([t,d]) => {
      const {x,y} = this._tc(t,d);
      ctx.beginPath(); ctx.arc(x, y, 6, 0, Math.PI*2);
      ctx.fillStyle = this.deleteMode ? '#ff5252' : '#00c8e0';
      ctx.fill();
      ctx.strokeStyle = this.deleteMode ? '#ff7575' : '#ffffff';
      ctx.lineWidth = 1.5; ctx.stroke();

      // Label bubble
      const label = `${t}deg/${d}%`;
      ctx.font = `9px 'Share Tech Mono', monospace`;
      const tw = ctx.measureText(label).width;
      const lx = Math.min(Math.max(x, pl + tw/2 + 4), W - pr - tw/2 - 4);
      const ly = y > pt + 20 ? y - 14 : y + 20;
      ctx.fillStyle = 'rgba(20,22,30,.9)';
      ctx.fillRect(lx - tw/2 - 3, ly - 10, tw + 6, 13);
      ctx.fillStyle = this.deleteMode ? '#ff9090' : '#7ec8d8';
      ctx.textAlign = 'center';
      ctx.fillText(label, lx, ly);
    });
  }
}

// ---- Curve editor instances ----
let editors = window.editors = {};
let deleteModes = { 1: false, 2: false };

function initEditors(settings) {
  editors[1] = new CurveEditor('curve1', settings.fan1_curve, curve => {
    currentSettings.fan1_curve = curve;
    if (document.getElementById('syncCurves').checked) {
      currentSettings.fan2_curve = curve.map(p => [...p]);
      editors[2].setCurve(curve);
    }
  });
  editors[2] = new CurveEditor('curve2', settings.fan2_curve, curve => {
    currentSettings.fan2_curve = curve;
  });
}

function toggleDelete(n) {
  deleteModes[n] = !deleteModes[n];
  editors[n].deleteMode = deleteModes[n];
  editors[n].render();
  const btn = document.getElementById(`delBtn${n}`);
  btn.style.borderColor = deleteModes[n] ? 'var(--hot)' : '';
  btn.style.color       = deleteModes[n] ? 'var(--hot)' : '';
  btn.textContent       = deleteModes[n] ? 'Done' : 'Delete Point';
}

function onSyncChange() {
  const sync = document.getElementById('syncCurves').checked;
  if (sync && currentSettings) {
    currentSettings.fan2_curve = currentSettings.fan1_curve.map(p => [...p]);
    editors[2].setCurve(currentSettings.fan1_curve);
  }
}

// ---- Settings save ----
async function saveSettings(settings) {
  try {
    // Form-encode the body so Unraid CSRF middleware can validate
    const body = new URLSearchParams();
    body.set('csrf_token', CSRF);
    body.set('data', JSON.stringify(settings));

    const r = await fetch(`${API}&action=settings`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: body.toString()
    });
    const text = await r.text();
    if (!r.ok) {
      throw new Error(`HTTP ${r.status}: ${text.slice(0, 80)}`);
    }
    let j;
    try { j = JSON.parse(text); }
    catch(e) { throw new Error('Server response not JSON: ' + text.slice(0, 80)); }
    if (!j.ok) throw new Error(j.error || 'Save failed');
    toast('Settings saved', 'ok');
  } catch(e) {
    toast('Save failed: ' + e.message, 'error');
  }
}

async function saveCurve(n) {
  const btn = document.getElementById(`saveBtn${n}`);
  btn.disabled = true;
  await saveSettings(currentSettings);
  btn.classList.add('saved');
  btn.textContent = 'Saved ';
  setTimeout(() => {
    btn.classList.remove('saved');
    btn.textContent = `Save Fan ${n} Curve`;
    btn.disabled = false;
  }, 2000);
}

// ---- Daemon control ----
async function restartDaemon() {
  toast('Restarting daemon...', '');
  const body = new URLSearchParams();
  body.set('csrf_token', CSRF);
  body.set('data', JSON.stringify({cmd:'restart'}));
  await fetch(`${API}&action=service`, {
    method: 'POST',
    headers: {'Content-Type':'application/x-www-form-urlencoded'},
    body: body.toString()
  });
  toast('Daemon restarted', 'ok');
}

// ---- Log ----
async function fetchLog() {
  const box = document.getElementById('logBox');
  try {
    const r = await fetch(`${API}&action=log&lines=80`);
    const j = await r.json();
    box.innerHTML = (j.lines || []).map(l => {
      const cls = l.includes(' ERROR ') ? 'll-error' :
                  l.includes(' WARNING') ? 'll-warn' :
                  l.includes(' INFO ') ? 'll-info' : '';
      return `<span class="${cls}">${escHtml(l)}</span>`;
    }).join('\n');
    box.scrollTop = box.scrollHeight;
  } catch(e) {
    box.textContent = 'Log unavailable';
  }
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ---- Toast ----
let _toastTimer;
function toast(msg, type='') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show ' + type;
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => el.className = '', 2800);
}

// ---- Poll loop ----
let _settingsLoaded = false;

async function poll() {
  try {
    const r = await fetch(`${API}&action=status`);
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const s = await r.json();
    if (s.error) throw new Error(s.error);

    updateGauges(s);
    if (s.history) updateCharts(s.history);

    // Sync pump mode highlight
    if (s.pump_mode && currentSettings) {
      currentSettings.pump_mode = s.pump_mode;
      highlightPumpMode(s.pump_mode);
    }

    document.getElementById('statusDot').className  = 'status-dot live';
    const ts = new Date(s.timestamp);
    document.getElementById('statusText').textContent =
      `Live . ${String(ts.getHours()).padStart(2,'0')}:${String(ts.getMinutes()).padStart(2,'0')}:${String(ts.getSeconds()).padStart(2,'0')}`;

  } catch(e) {
    document.getElementById('statusDot').className  = 'status-dot error';
    document.getElementById('statusText').textContent = 'No data - ' + e.message;
  }
}

async function init() {
  // Load settings once to init curve editors and pump mode
  try {
    const r = await fetch(`${API}&action=settings`);
    currentSettings = await r.json();
    _settingsLoaded  = true;
    highlightPumpMode(currentSettings.pump_mode);
    initEditors(currentSettings);
  } catch(e) {
    // Will retry implicitly
  }

  // Populate device name in header
  try {
    const dr = await fetch(`${API}&action=devices`);
    const dj = await dr.json();
    if (dj.devices && dj.devices.length) {
      const names = dj.devices.map(d => d.name).join(' . ');
      document.getElementById('deviceName').textContent = names;
    }
  } catch(e) { /* no-op */ }

  fetchLog();
  await poll();
  setInterval(poll, 2000);
  setInterval(fetchLog, 30000);
}

document.addEventListener('DOMContentLoaded', init);
</script>

</div>
