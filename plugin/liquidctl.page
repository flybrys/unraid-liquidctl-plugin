canvas.chart { width: 100% !important; height: 160px !important; }

/* ---- Controls row ---- */
.controls-grid {
  display: grid;
  grid-template-columns: 280px 1fr 1fr;
  gap: 14px;
  align-items: start;
}
@media (max-width: 1100px) { .controls-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 700px)  { .controls-grid { grid-template-columns: 1fr; } }

/* Pump mode card */
.pump-modes { display: flex; flex-direction: column; gap: 8px; margin-top: 4px; }
.pump-btn {
  display: flex; align-items: center; gap: 12px;
