.btn-save:hover { background: var(--accent); color: var(--bg); }
.btn-save:disabled { opacity: .4; cursor: default; }
.btn-save.saved { background: rgba(105,240,174,.15); border-color: var(--ok); color: var(--ok); }

/* ---- Sync toggle ---- */
.sync-toggle {
  display: flex; align-items: center; gap: 8px;
  font-size: 12px; color: var(--muted); margin-top: 8px; cursor: pointer;
}
.sync-toggle input { accent-color: var(--accent); }

/* ---- Log section ---- */
.log-box {
  background: #050508; border: 1px solid var(--border);
  border-radius: 8px; padding: 12px 14px;
  font-family: var(--font-mono); font-size: 11px; color: #556;
  max-height: 180px; overflow-y: auto;
