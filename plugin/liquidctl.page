<style>
/* ---- Reset & base ---- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:         #08090d;
  --s1:         #0d0f15;
  --s2:         #13151d;
  --s3:         #1a1c26;
  --border:     #23263080;
  --border-hi:  #2d3145;
  --text:       #b8c4d8;
  --muted:      #454d62;
  --accent:     #00c8e0;
  --accent-dim: rgba(0,200,224,.12);
  --accent-glow:rgba(0,200,224,.25);
  --temp-col:   #ff7043;
  --fan-col:    #40c4ff;
  --pump-col:   #b388ff;
  --ok:         #69f0ae;
  --warn:       #ffd740;
  --hot:        #ff5252;
  --font-ui:    'Rajdhani', sans-serif;
  --font-mono:  'Share Tech Mono', monospace;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-ui);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
  padding: 0 0 40px;
}

/* ---- Header ---- */
.header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 18px 28px 16px;
  border-bottom: 1px solid var(--border);
  background: var(--s1);
}
.header-icon {
  width: 38px; height: 38px;
  background: var(--accent-dim);
  border: 1px solid var(--accent);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
}
.header-title { font-size: 22px; font-weight: 700; letter-spacing: .04em; color: #e0ecf8; }
.header-sub   { font-size: 12px; color: var(--muted); letter-spacing: .08em; text-transform: uppercase; }
.header-right { margin-left: auto; display: flex; align-items: center; gap: 16px; }
.status-badge {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--font-mono); font-size: 12px; color: var(--muted);
}
.status-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--muted);
  transition: background .4s;
}
.status-dot.live { background: var(--ok); box-shadow: 0 0 6px var(--ok); animation: pulse 2s infinite; }
.status-dot.error { background: var(--hot); }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

.btn-sm {
  font-family: var(--font-ui); font-size: 12px; font-weight: 600;
  letter-spacing: .06em; text-transform: uppercase;
  padding: 5px 12px; border-radius: 5px; cursor: pointer;
  border: 1px solid var(--border-hi);
  background: var(--s3); color: var(--text);
  transition: all .15s;
}
.btn-sm:hover { border-color: var(--accent); color: var(--accent); }
.btn-sm.danger:hover { border-color: var(--hot); color: var(--hot); }

/* ---- Layout ---- */
.page { max-width: 1400px; margin: 0 auto; padding: 24px 28px; }

section { margin-bottom: 24px; }
.section-title {
  font-size: 11px; font-weight: 600; letter-spacing: .12em;
  text-transform: uppercase; color: var(--muted);
  margin-bottom: 12px; padding-left: 2px;
}

/* ---- Card ---- */
.card {
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 20px;
  position: relative;
  overflow: hidden;
}
.card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--border-hi), transparent);
}

/* ---- Gauges row ---- */
.gauges-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
@media (max-width: 900px) { .gauges-grid { grid-template-columns: repeat(2, 1fr); } }

.gauge-card {
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 18px 20px 14px;
  position: relative; overflow: hidden;
}
.gauge-card::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
  background: var(--col, var(--accent));
  opacity: .5;
}
.gauge-label {
  font-size: 11px; font-weight: 600; letter-spacing: .1em;
  text-transform: uppercase; color: var(--muted);
  margin-bottom: 8px;
}
.gauge-value {
  font-family: var(--font-mono);
  font-size: 38px;
  color: var(--col, var(--accent));
